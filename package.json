{
  "name": "tsc-esm-imports",
  "version": "1.0.0",
  "description": "Fix missing .js extensions in tsc output for Node.js ESM compatibility",
  "author": "Gabriel Llamas",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/gagle/tsc-esm-imports.git"
  },
  "bugs": {
    "url": "https://github.com/gagle/tsc-esm-imports/issues"
  },
  "homepage": "https://github.com/gagle/tsc-esm-imports#readme",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.15.0",
  "bin": {
    "tsc-esm-imports": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "keywords": [
    "typescript",
    "esm",
    "import",
    "extensions",
    "tsc",
    "postbuild",
    "module",
    "fix",
    "specifiers",
    "node",
    "esm-imports",
    "build"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/postbuild.mjs",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
